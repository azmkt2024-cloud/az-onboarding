# 이 파일은 "예시 템플릿"입니다 (git 추적됨). 실제 키는 절대 여기 넣지 마세요.
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 .gitignore 로 커밋에서 제외됩니다).

# Supabase — 대시보드 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 (절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron 인증용 랜덤 시크릿
CRON_SECRET=your-random-secret

# (오프라인 전용) 배치 스크립트용 — 런타임 앱에서는 사용하지 않음.
# scripts/extract_answer_keys.mjs, scripts/rewrite_qna_batch.mjs 실행 시 필요.
ANTHROPIC_API_KEY=sk-ant-...
